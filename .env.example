# ----------------------------------------------------------------------------
# Frontend environment variables
# Copy this file to `.env.local` and tweak per-environment.
# ----------------------------------------------------------------------------

# Base URL of the FastAPI backend. NO trailing slash.
# Local dev:   http://localhost:5000
# Staging:     https://api.staging.agripilot.example.com
# Production:  https://api.agripilot.example.com
# Used by every fetch in src/lib/api/*, src/features/**/api.ts, and the
# Next.js route handlers under src/app/api/*.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Supabase (optional — app falls back to demo data when blank)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side AI key (optional)
AI_PROVIDER_API_KEY=

# Marketplace (optional — backend uses static distance matrix when blank)
GOOGLE_MAPS_API_KEY=
